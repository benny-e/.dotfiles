// NIRI COMPOSITOR CONFIGURATION

// STARTUP

spawn-at-startup "waybar" 
spawn-at-startup "mako"
spawn-at-startup "wl-paste" "--watch" "cliphist" "store"
spawn-at-startup "swayidle" "-w"
// INPUT DEVICES

input {
    focus-follows-mouse max-scroll-amount="0%"

    keyboard {
        xkb {
            layout "us"
        }
        repeat-delay 300
        repeat-rate 25
    }

    mouse {
        accel-speed 0.8
        accel-profile "flat"
    }

    touchpad {
        tap
        dwt
        natural-scroll
        accel-speed 0.2
    }
}

// OUTPUT CONFIGURATION

output "eDP-1" {
    mode "1920x1080@239.964"
    scale 1.0
    transform "normal"
}

// LAYOUT

layout {
    gaps 10

    center-focused-column "on-overflow"
    always-center-single-column

    background-color "transparent"

    default-column-width { proportion 0.5; }

    preset-window-heights {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    focus-ring {
        off
    }

    border {
        on

        width 0
        active-gradient from="#ffd75f" to="#ffafd7"
        inactive-color "#5eaaff"
    }


    shadow {
        on

        softness 60
        spread 5
        offset x=0 y=10
        color "#00000059"
    }

    insert-hint {
        color "#5f472dAA"
    }

    default-column-display "normal"

    tab-indicator {
        hide-when-single-tab
        length total-proportion=1.002
        gap 0
        width 3
        position "top"
        inactive-color "#00000000"
        active-color "#af87ff"
    }
}

// WORKSPACES

workspace "1"
workspace "2"
workspace "3"
workspace "4"
workspace "5"
workspace "6"
workspace "7"
workspace "8"
workspace "9"
// VISUAL PREFERENCES

prefer-no-csd

hotkey-overlay {
    hide-not-bound
    skip-at-startup
}

// OVERVIEW

overview {
    zoom 0.5
    backdrop-color "#00000080"

    workspace-shadow {
        off
    }
}

// SCREENSHOT

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// WINDOW SWITCHER

recent-windows {
    debounce-ms 750
    open-delay-ms 150

    highlight {
        active-color "#777777ff"
        urgent-color "#ff9999ff"
        padding 30
        corner-radius 0
    }

    previews {
        max-height 480
        max-scale 0.5
    }
}

// WINDOW RULES

window-rule {
    match is-active=false
    draw-border-with-background false
    clip-to-geometry true
    opacity 0.92
    border {
        off
    }
}

window-rule {
    match is-active=true
    draw-border-with-background false
    clip-to-geometry true
    opacity 0.98
}

window-rule {
    geometry-corner-radius 0
}

window-rule {
    match is-floating=true
    geometry-corner-radius 0
}

// FLOATING WINDOW RULES

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match title=r#"^(Open|Save|Select|Choose)"#
    open-floating true
}

window-rule {
    match app-id=r#"^(pavucontrol|gnome-calculator|org\.gnome\.Calculator)$"#
    open-floating true
}

// TERMINAL WIDTH PRESETS

window-rule {
    match app-id=r#"foot|ghostty|kitty|wezterm"#
    default-column-width { proportion 0.5; }
}


// GESTURES

gestures {
    hot-corners {
        off
    }
}

// KEYBINDINGS

binds {
    // APPLICATIONS

    Mod+Return { spawn "kitty"; }
    Mod+R { spawn-sh "rofi -show drun -theme ~/.config/rofi/launcher.rasi"; }
    Mod+B {spawn "firefox";}

    // OVERVIEW

    Mod+O { toggle-overview; }

    // SCREENSHOTS

    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }

   //Clipboard

   Mod+C {spawn "~/.config/niri/scripts/clipboard.sh";}

    // WINDOW MANAGEMENT

    Mod+Q { close-window; }
    Mod+F { maximize-column; }

    // FLOATING WINDOWS

    Mod+V { toggle-window-floating; }
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    // FOCUS NAVIGATION

    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+Left { focus-column-left; }
    Mod+Down { focus-window-down; }
    Mod+Up { focus-window-up; }

    // WINDOW MOVEMENT

    Mod+Shift+H { move-column-left; }
    Mod+Shift+L { move-column-right; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }
    Mod+Shift+Left { move-column-left; }
    Mod+Shift+Right { move-column-right; }
    Mod+Shift+Down { move-window-down; }
    Mod+Shift+Up { move-window-up; }
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    

    // WORKSPACE NAVIGATION

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }

    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }

    // MOVE WINDOW TO WORKSPACE

    Mod+Shift+1 { move-window-to-workspace 1; }
    Mod+Shift+2 { move-window-to-workspace 2; }
    Mod+Shift+3 { move-window-to-workspace 3; }
    // COLUMN & WINDOW SIZING


    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // MEDIA CONTROLS

    XF86AudioRaiseVolume { spawn-sh "~/.config/niri/scripts/volume-osd.sh up"; }
    XF86AudioLowerVolume { spawn-sh "~/.config/niri/scripts/volume-osd.sh down"; }

    XF86AudioMute { spawn-sh "~/.config/niri/scripts/volume-osd.sh mute"; }

    XF86AudioPlay { spawn "playerctl" "play-pause"; }
    XF86AudioPause { spawn "playerctl" "play-pause"; }
    XF86AudioNext { spawn "playerctl" "next"; }
    XF86AudioPrev { spawn "playerctl" "previous"; }

    // BRIGHTNESS CONTROLS

    XF86MonBrightnessUp { spawn-sh "~/.config/niri/scripts/brightness-osd.sh up" ;}
    XF86MonBrightnessDown { spawn-sh "~/.config/niri/scripts/brightness-osd.sh down"; }


    // SYSTEM CONTROLS

    Mod+Alt+L {spawn "hyprlock" ; }

    Mod+Shift+E { quit; }
}


